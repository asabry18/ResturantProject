  if (typeof window.trc_itemRenderer == 'function') window.trc_itemRenderer(document.createElement('div'), data, false);
  
	/** START - Create default CTA button **/
	var itemLabelBox = box.getElementsByClassName('item-label-href');
	var videoLabelBox = box.getElementsByClassName("video-label-box")
  itemLabelBox[0].classList.add("video-cta-style");
  itemLabelBox[0].classList.add("non-feed-cta-item");
  videoLabelBox[0].classList.add("video-label-box-cta");
  videoLabelBox[0].classList.add("video-label-box-cta-non-ie");
  box.getElementsByClassName("branding composite-branding")[0].classList.add("video-branding-flex-cta-item");
  for (var i = 0; i < box.getElementsByClassName("video-label").length; i++) {
    box.getElementsByClassName("video-label")[i].classList.add("video-label-flex-cta-item");
  }

  var newCtaDiv = document.createElement("div");
  newCtaDiv.classList.add("video-cta-href");
  newCtaDiv.classList.add("list-suffix-show-cta");

  var ctaButton = document.createElement("button");
  ctaButton.type = "button";
  ctaButton.classList.add("video-cta-button");
  ctaButton.classList.add("video-cta-style");
  ctaButton.style = "border-color: rgb(29, 34, 40); font-weight: bold; font-family: &quot;Helvetica Neue&quot;; color: rgb(29, 34, 40);";

  if (typeof data["cta-text"] === "undefined") {
    ctaButton.textContent = "Learn More";
  } else {
    ctaButton.textContent = data["cta-text"];
  }
	newCtaDiv.appendChild(ctaButton);
	/** END - Create default CTA button **/
	
	/** START - Move disclosure text **/
	var discText = box.querySelector(".branding .logoDiv");
	itemLabelBox[0].insertBefore(discText, videoLabelBox[0]);
	/** END - Move disclosure text **/
	
	/** START - Allow title to wrap when description text is empty **
  if (data["description"] === "") box.getElementsByClassName('video-title')[0].classList.add("no-video-description");
	/** END - Allow title to wrap when description text is empty **/
	
	// box.getElementsByClassName('video-description')[0].innerHTML = "";
	
	/** START - Move title/description into div **/
	var vidLabelBox = box.getElementsByClassName("video-label-box")[0];
	var vidTitle = box.getElementsByClassName("video-title")[0];
	var vidDescription = box.getElementsByClassName("video-description")[0];
	var newVidDiv = document.createElement("div");
	newVidDiv.classList.add("tbl-title-description-box");
	vidLabelBox.appendChild(newVidDiv);
	if (data["description"] === "") { 
		newVidDiv.appendChild(vidTitle);
		vidLabelBox.appendChild(vidDescription);
	} else {
		newVidDiv.appendChild(vidDescription);
	}
	newVidDiv.appendChild(newCtaDiv);
	/** END - Move titledescription into div **/
