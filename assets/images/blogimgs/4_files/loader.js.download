  if (typeof window.trc_itemRenderer == 'function')
    window.trc_itemRenderer(document.createElement('div'), data, false);

  /** START FUNCTION - Add default CTA button to element **/
  function addCTAbutton(element, font, defaultText) {
		try {
			var itemLabelBox = box.getElementsByClassName('item-label-href');
			var videoLabelBox = box.getElementsByClassName("video-label-box");
			itemLabelBox[0].classList.add("video-cta-style");
			itemLabelBox[0].classList.add("non-feed-cta-item");
			videoLabelBox[0].classList.add("video-label-box-cta");
			videoLabelBox[0].classList.add("video-label-box-cta-non-ie");
			box.getElementsByClassName("branding")[0].classList.add("video-branding-flex-cta-item");
			for (var i = 0; i < box.getElementsByClassName("video-label").length; i++) {
				box.getElementsByClassName("video-label")[i].classList.add("video-label-flex-cta-item");
			}

			var newCtaDiv = document.createElement("div");
			newCtaDiv.classList.add("video-cta-href");
			newCtaDiv.classList.add("list-suffix-show-cta");

			var ctaButton = document.createElement("button");
			ctaButton.type = "button";
			ctaButton.classList.add("video-cta-button");
			ctaButton.classList.add("video-cta-style");
			ctaButton.style = "border-color: rgb(29, 34, 40); font-weight: bold; font-family: &quot;" + font + "&quot;; color: rgb(29, 34, 40);";

			if (typeof data["cta-text"] === "undefined") {
				ctaButton.textContent = defaultText;
			} else {
				ctaButton.textContent = data["cta-text"];
			};

			newCtaDiv.appendChild(ctaButton);
			element.appendChild(newCtaDiv);
		} catch (e) {
				__trcError('Error in [item-renderer] [addCTAbutton] ' + e.message);
		};
  }
  /** END FUNCTION - Add default CTA button to element **/

  /** START FUNCTION - Add arrow to CTA text **/
  function addArrow(element) {
		try {
			var arrowIconSpan = document.createElement("span");
			var arrowIconSvg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
			var arrowIconPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
			arrowIconSpan.classList.add("tbl-arrow-icon-span");
			arrowIconSvg.classList.add("tbl-arrow-icon-svg");
			arrowIconSvg.setAttribute("viewBox", "0 0 20 20");
			arrowIconPath.setAttribute("d", "M14.8 8.5l-5-5-5 5c-.3.3-.3.8 0 1.1s.8.3 1.1 0L9 6.4v9.4c0 .4.3.8.8.8s.8-.3.8-.8V6.4l3.2 3.2c.1.1.3.2.5.2s.4-.1.5-.2c.3-.3.3-.8 0-1.1z");
